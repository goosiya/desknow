# =============================================================================
# desknow 백엔드 환경변수 예시 (apps/api/.env.example)
# -----------------------------------------------------------------------------
# 사용법:
#   1) 이 파일을 복사해서 같은 폴더에 `.env`로 저장: cp .env.example .env
#   2) 각 변수에 소유자가 발급받은 실제 값을 채웁니다.
#   3) `uv run python -m app.core.config --check` 로 로드 여부를 검증합니다.
#
# ⚠️ 이 파일에는 절대 실제 비밀 값을 넣지 마세요(플레이스홀더만). 추적되는 파일입니다.
#    실제 값은 `.env`에만 넣으며, `.env`는 .gitignore로 추적에서 제외됩니다.
#    키 발급 방법은 docs/external-services-setup.md 참고.
# =============================================================================

# -----------------------------------------------------------------------------
# [필수] 카카오 디벨로퍼스 (https://developers.kakao.com → 내 애플리케이션 → 앱 키)
# -----------------------------------------------------------------------------
# 용도: 지오코딩/주소 변환 (백엔드 전용)
# 획득 출처: 카카오 콘솔 → 앱 키 → REST API 키
KAKAO_REST_API_KEY=your-kakao-rest-api-key

# 용도: 웹 지도 JS SDK (프론트에 노출되는 유일한 키 — 도메인 화이트리스트 필수)
# 획득 출처: 카카오 콘솔 → 앱 키 → JavaScript 키
KAKAO_JS_KEY=your-kakao-javascript-key

# -----------------------------------------------------------------------------
# [필수] OpenAI (https://platform.openai.com → API keys)
# -----------------------------------------------------------------------------
# 용도: 기준 LLM(GPT) + 임베딩 (백엔드 전용, 결제 수단 등록 필요)
# 획득 출처: OpenAI 플랫폼 → API keys → Create new secret key
OPENAI_API_KEY=sk-your-openai-api-key

# 용도: 임베딩 모델명 (단일 고정 — 교체 시 전체 재임베딩 필요)
# 기본값이 이 값이므로 변경 불필요. 비워두면 기본값 text-embedding-3-small 적용.
EMBEDDING_MODEL=text-embedding-3-small

# -----------------------------------------------------------------------------
# [필수] 데이터베이스 (PostgreSQL + pgvector) — Story 1.4부터 필수
# -----------------------------------------------------------------------------
# 용도: SQLModel 엔진 + Alembic 마이그레이션 연결 (백엔드 전용, 비밀번호 포함 비밀)
# 개발 DB = Supabase 권장. 획득 출처:
#   Supabase 콘솔 → Project Settings → Database → Connection string
#   ⚠️ 반드시 직접 연결 또는 Session pooler의 5432 포트를 사용하세요.
#      Transaction pooler(6543)는 prepared statement/세션 상태를 끊어
#      Alembic 마이그레이션·일부 psycopg3 기능이 깨집니다.
# 스킴: provider가 주는 postgresql://·postgres://를 그대로 붙여도 됩니다
#      (psycopg3용 postgresql+psycopg://로 자동 정규화).
DATABASE_URL=postgresql+psycopg://user:password@host:5432/desknow

# -----------------------------------------------------------------------------
# [선택] 라이브 통합/골든셋 테스트용 DB — 보통 DATABASE_URL(Supabase=현 test DB)과 동일
# -----------------------------------------------------------------------------
# 운영 DB는 Railway PostgreSQL이고, Supabase는 dev/test DB다 → 테스트는 Supabase를 겨눈다.
# opt-in: pytest는 .env를 자동 로드하지 않는다. 라이브 게이트(rooms 마이그레이션·golden set·
#   ingest 통합)를 켜려면 export TEST_DATABASE_URL="$DATABASE_URL" 후 pytest 실행. 미설정 시 skip.
# ⚠️ golden set teardown이 DELETE FROM document_chunks(전체) → dev 코퍼스 청크가 비워진다.
#    실행 후 챗봇 문서 인제스트(8.4)로 재적재할 것(특히 dump→Railway 배포 직전).
# TEST_DATABASE_URL=postgresql+psycopg://user:password@host:5432/postgres

# -----------------------------------------------------------------------------
# [필수] JWT 서명 키 (백엔드 전용 비밀) — Story 1.8부터 필수
# -----------------------------------------------------------------------------
# 용도: access/refresh JWT의 HS256 서명·검증 키(단일 백엔드 발급). 절대 프론트에 노출 금지.
# ⚠️ 최소 32자 이상이어야 합니다(미만이면 기동 fail-fast — InsecureKeyLengthWarning 방지).
# 생성법: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-generate-a-long-random-secret

# -----------------------------------------------------------------------------
# [선택] 멀티 LLM best-effort — 미설정 시 해당 경로만 비활성화, 기동은 정상
# -----------------------------------------------------------------------------
# 용도: Anthropic Claude (백엔드 전용)
# 획득 출처: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# 용도: Google Gemini (백엔드 전용)
# 획득 출처: https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=

# -----------------------------------------------------------------------------
# [선택] 카카오 네이티브 앱 키 — RN 앱 카카오 공유용
# 획득 출처: 카카오 콘솔 → 앱 키 → 네이티브 앱 키
# -----------------------------------------------------------------------------
KAKAO_NATIVE_APP_KEY=

# -----------------------------------------------------------------------------
# [선택] LLM 프로바이더/모델 선택 (Story 7.1 — 멀티 LLM 어댑터)
# 설정값만 바꾸면 챗봇이 프로바이더/모델을 전환한다(코드 변경 불필요).
# 기본값이 채워져 있으므로 변경 불필요. 비워두면 기본값(openai / 기준 모델) 적용.
# -----------------------------------------------------------------------------
# 용도: 챗봇이 사용할 LLM 프로바이더. openai|anthropic|google 중 하나.
#   - openai = 기준 프로바이더(≤2초 SLA, OPENAI_API_KEY 필수)
#   - anthropic|google = best-effort(각각 ANTHROPIC_API_KEY/GOOGLE_AI_API_KEY 설정 시에만 선택 가능)
LLM_PROVIDER=openai

# 용도: 위 프로바이더의 모델 id. 기본값은 기준 OpenAI 모델.
#   ⚠️ 모델 id는 시점에 따라 바뀝니다 — 배포 시 프로바이더 콘솔에서 현행 id를 확인하세요.
LLM_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# [선택] 시드 관리자 부트스트랩 (Story 8.1 — scripts/seed_admin.py 전용)
# -----------------------------------------------------------------------------
# 용도: 시드 관리자 계정을 1회 부트스트랩한다(관리자는 가입 불가 — 시드만 존재).
#   `python scripts/seed_admin.py`(또는 `uv run python scripts/seed_admin.py`)가 이 두 값으로
#   멱등 생성/갱신한다. **앱 기동과 무관**(미설정이어도 API는 정상 기동).
# ⚠️ 운영 비밀이므로 라이브에서는 .env/Railway 변수로만 주입 — 이 추적 파일엔 실제 비밀 금지.
SEED_ADMIN_EMAIL=admin@desknow.kr
SEED_ADMIN_PASSWORD=change-me-strong-password
