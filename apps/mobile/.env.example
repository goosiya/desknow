# 모바일 앱이 바라보는 백엔드 API base URL.
#
# ⚠️ 모바일(실기기/에뮬레이터)은 `localhost`로 개발 머신의 백엔드에 닿지 못한다.
#    개발 머신의 LAN IP로 지정해야 한다(값은 머신·네트워크마다 다름 → 각자 채울 것).
#    LAN IP 확인: Windows `ipconfig`(IPv4 주소), macOS/Linux `ifconfig`/`ip addr`.
#    백엔드는 LAN 접근을 위해 `uvicorn --host 0.0.0.0`으로 기동해야 한다(Story 1.2 Task 6).
#
# Expo는 EXPO_PUBLIC_ 접두사 환경변수를 클라이언트 번들에 자동 주입한다.
# ⚠️ origin만 (Story 1.9) — 경로(/api/v1/...)는 생성 SDK(@desknow/api-client)에 포함되므로
#    /api/v1을 붙이면 경로가 중복된다. 백엔드 호출은 SDK로만(직접 fetch 금지 — eslint 가드).
EXPO_PUBLIC_API_BASE_URL=http://192.168.0.2:8000

# ── Phase 0 스파이크 ② SSE (Story 1.3, throwaway) ─────────────────────────
# standalone 스파이크 서버(:8001). RN은 localhost 미접근 → 개발 머신 LAN IP로 교체(예시이며 그대로는 동작 안 함).
EXPO_PUBLIC_SPIKE_BASE=http://192.168.0.2:8001

# ── 카카오 지도 JS 키 (Story 9.1) ─────────────────────────────────────────
# WebView 카카오맵 캔버스가 쓰는 JS 키(REST 키 금지 — 프론트 노출 키는 도메인 화이트리스트 JS 키만).
# apps/api/.env의 KAKAO_JS_KEY(=웹 NEXT_PUBLIC_KAKAO_JS_KEY)와 동일 값을 쓴다.
# ⚠️ WebView origin(baseUrl)이 카카오 콘솔 [플랫폼→Web] 화이트리스트에 등록돼야 SDK가 거부하지 않는다.
EXPO_PUBLIC_KAKAO_JS_KEY=

# ── E2E 세션주입 하니스 게이트 (Story 9.1, AC7) ───────────────────────────
# "1"일 때만(그리고 __DEV__ 개발 빌드에서만) Expo Web 전역에 window.__DESKNOW_E2E__ 주입 훅을
# 노출한다(프로덕션 빌드는 __DEV__ dead-code 제거로 미포함). Playwright(MCP) 수동 E2E 구동용.
EXPO_PUBLIC_E2E_ENABLED=

# ── 예약 공유 링크 origin (Story 9.2, AC7) ────────────────────────────────
# 예약 공유 텍스트에 들어가는 룸 상세 링크의 origin(`${EXPO_PUBLIC_WEB_ORIGIN}/rooms/{room_id}`).
# 등록 웹(Next.js) origin을 쓴다(개발=localhost:3000, 운영=배포 도메인). RN 내장 Share.share()가
# 이 텍스트를 OS 공유 시트에 싣는다(카카오 전용 모듈은 EAS dev-build 버킷 보류 — §deferred).
EXPO_PUBLIC_WEB_ORIGIN=http://localhost:3000
